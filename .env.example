# MOST2 / NTLM auth (domain\username supported; backslash is literal in .env)
USERNAME=fdc\your_username
PASSWORD=your_password

# MOST2 endpoint
EMS_BASE_URL=https://most2.emscorporate.com
EMS_SEARCH_PATH=/WebService.asmx/ticket_search_load_grid

# Search defaults applied when no UI filter is set
EMS_TICKET_STATUS=O

# Pagination guardrails for live MOST2 calls
EMS_PAGE_SIZE=500
EMS_MAX_PAGES=20

# In-memory result cache (seconds). 0 disables.
SEARCH_CACHE_TTL=600

# Flask
FLASK_HOST=127.0.0.1
FLASK_PORT=5003
FLASK_DEBUG=False
SECRET_KEY=change-me
